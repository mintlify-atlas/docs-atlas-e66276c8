  "keyFeatures": [
    "Multi-currency digital wallets",
    "Money transfer between users (email/phone/QR)",
    "Deposit and withdrawal with multiple payment gateways (Stripe, PayPal, Bank, CoinPayments, Payeer)",
    "Currency exchange with live rates",
    "Merchant and cashier management with shift tracking",
    "QR code-based payments (standard and express)",
    "Invoice creation and management",
    "Request payment (send/accept/cancel)",
    "KYC document verification",
    "Two-factor authentication (SMS and Google Authenticator)",
    "Role-based access control with permissions",
    "Admin dashboard with analytics and reporting",
    "Group-based fund distribution",
    "Event ticketing with cart and checkout",
    "Dispute and support ticket management",
    "Firebase push notifications",
    "Activity logging and audit trail",
    "Multi-language support"
  ],
